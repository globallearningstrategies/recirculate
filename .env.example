# --- Core ---
APP_BASE_URL=https://your-app.vercel.app
CRON_SECRET=generate_a_long_random_string

# --- Supabase ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service_role_key_keep_secret
SUPABASE_STORAGE_BUCKET=clips

# --- YouTube (Google Cloud OAuth client) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/callback/youtube

# --- Instagram (Meta app, Graph API) ---
META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v21.0
META_REDIRECT_URI=https://your-app.vercel.app/api/callback/instagram

# --- TikTok (TikTok for Developers) ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://your-app.vercel.app/api/callback/tiktok
